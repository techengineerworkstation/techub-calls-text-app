{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["TELNYX_API_KEY", "TELNYX_PHONE_NUMBER", "TELNYX_SIP_CONNECTION_ID", "NEXT_PUBLIC_APP_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {}
  }
}
